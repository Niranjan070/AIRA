# Inference Mode: auto | local | gemini
#   auto   = try local GPU first, fall back to Gemini API if local fails
#   local  = GPU models only (requires model server running)
#   gemini = Gemini API only (fast, no GPU needed, requires API key)
INFERENCE_MODE=auto

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_api_key_here

# Gemini Model
GEMINI_MODEL=gemini-2.0-flash

# Server Configuration
PORT=8000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
